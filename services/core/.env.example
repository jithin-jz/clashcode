# Core Service Settings
SECRET_KEY=django-insecure-development-key-replace-me
DEBUG=True

# Database Connection (Host connecting to Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clashcode_db
DB_USER=postgres
DB_PASSWORD=postgres

# Redis & Cache
REDIS_URL=redis://localhost:6379/0

# Allowed Hosts & URLs
ALLOWED_HOSTS=localhost,127.0.0.1,core
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost

# Email (SMTP for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=CLASHCODE <no-reply@localhost>

# OAuth (Placeholders)
GITHUB_CLIENT_ID=your_id
GITHUB_CLIENT_SECRET=your_secret
GOOGLE_CLIENT_ID=your_id
GOOGLE_CLIENT_SECRET=your_secret

# JWT (Base64 keys for easy dev setup)
# Local development can use JWT_SHARED_SECRET alone.
# For production, prefer RS256 and provide both JWT_PRIVATE_KEY and JWT_PUBLIC_KEY.
JWT_SHARED_SECRET=change-me-local-only
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# Optional Cloudinary media hosting
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
