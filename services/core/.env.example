# Core Service Settings
SECRET_KEY=replace-with-a-strong-random-secret
DEBUG=False

# Database Connection (Host connecting to Docker)
DB_HOST=db
DB_PORT=5432
DB_NAME=clashcode_db
DB_USER=clashcode
DB_PASSWORD=replace-with-a-strong-database-password

# Redis & Cache
REDIS_URL=redis://redis:6379/0

# Allowed Hosts & URLs
ALLOWED_HOSTS=your-domain.com,api.your-domain.com,core
FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Email (SMTP for development)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=no-reply@example.com
EMAIL_HOST_PASSWORD=replace-with-smtp-password
DEFAULT_FROM_EMAIL=CLASHCODE <no-reply@example.com>

# OAuth (Placeholders)
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# JWT (Base64 keys for easy dev setup)
# Production should use RS256 and provide both JWT_PRIVATE_KEY and JWT_PUBLIC_KEY.
JWT_SHARED_SECRET=
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_COOKIE_SECURE=True
JWT_COOKIE_SAMESITE=Lax
JWT_RETURN_TOKENS_IN_BODY=False

# Optional Cloudinary media hosting
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret

# Payments
RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret

# Internal service-to-service auth
INTERNAL_API_KEY=replace-with-long-random-internal-key
INTERNAL_SIGNING_SECRET=replace-with-long-random-signing-secret
INTERNAL_REQUIRE_SIGNATURE=True

# Code execution controls
EXECUTOR_URL=http://executor:8011/execute
CODE_EXECUTION_MAX_BYTES=65536
CODE_EXECUTION_TIMEOUT_SECONDS=15
THROTTLE_CODE_EXECUTION_RATE=12/minute
