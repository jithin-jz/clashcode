NGINX_HTTP_PORT=80
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.tjbxnwvkhgggtrbsnysp
DB_PASSWORD=your-supabase-password
DB_SSLMODE=require

INTERNAL_REQUIRE_SIGNATURE=true
INTERNAL_SIGNING_SECRET=replace-with-long-random-signing-secret

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# Use runsc after installing gVisor on the Docker host. Keep runc for local dev.
CONTAINER_RUNTIME=runc
EXECUTOR_CONTAINER_MEMORY=256m
EXECUTOR_CONTAINER_CPUS=1.0
EXECUTOR_MAX_CODE_BYTES=65536
EXECUTOR_TIMEOUT_SECONDS=5
EXECUTOR_MEMORY_LIMIT_MB=128
EXECUTOR_OUTPUT_LIMIT_BYTES=32768
EXECUTOR_BLOCK_DANGEROUS_IMPORTS=true


